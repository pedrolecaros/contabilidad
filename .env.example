# Copia este archivo como .env y ajusta los valores
# (el archivo .env nunca se sube a git)

# Ruta de la base de datos
# Linux/Mac — ruta local (por defecto, sin definir esta variable):
# DB_PATH=/home/usuario/contabilidad/contabilidad.db

# Windows con Google Drive:
# DB_PATH=C:\Users\Pedro\Google Drive\contabilidad\contabilidad.db

# Windows ruta normal:
# DB_PATH=C:\Users\Pedro\contabilidad\contabilidad.db

# Carpeta de adjuntos (opcional, por defecto es uploads/ dentro del proyecto)
# UPLOAD_FOLDER=C:\Users\Pedro\Google Drive\contabilidad\uploads

# Clave secreta (cambiar en producción)
# SECRET_KEY=una-clave-secreta-larga
